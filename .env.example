# Environment Configuration Template
# Copy file ini ke .env dan isi dengan nilai yang sebenarnya
# JANGAN commit file .env ke GitHub!

# Gemini API Key (dari https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Konfigurasi TTS
# TTS_GPU=false  # Set ke true jika ada GPU CUDA

# Optional: Konfigurasi model
# GEMINI_MODEL=models/gemma-4-31b-it
